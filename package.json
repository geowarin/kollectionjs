{
  "name": "kollectionjs",
  "version": "1.0.0",
  "private": false,
  "description": "Collection utilities inspired by kotlin for javascript",
  "license": "MIT",
  "author": "Geoffroy Warin",
  "repository": "https://geowarin/kollectionjs",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "format": "oxfmt --write .",
    "test": "vitest --run",
    "typecheck": "tsc --noEmit",
    "release": "bumpp",
    "docs": "typedoc",
    "prepublishOnly": "pnpm run build"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@typescript/native-preview": "7.0.0-dev.20260416.2",
    "bumpp": "^11.0.1",
    "oxfmt": "^0.45.0",
    "tsdown": "^0.21.7",
    "typedoc": "^0.28.19",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  }
}
